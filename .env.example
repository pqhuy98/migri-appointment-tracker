# Consecutive APPOINTMENT1, APPOINTMENT2, ... until APPOINTMENT{n} is unset.
# APPOINTMENT{i} = key:pin:type  —  type is prp or work (service UUID is hard-coded in the app).
# AUTHCHECK for API calls is obtained via pintest (key + PIN); do not set it in .env.
APPOINTMENT1=YOUR_KEY:YOUR_PIN:work

# APPOINTMENT2=OTHER_KEY:OTHER_PIN:prp

# Optional: Helsinki Malmi default if omitted
# MIGRI_OFFICE_ID=438cd01e-9d81-40d9-b31d-5681c11bd974

# How often to refresh booked appointment start time (ms). Default 300000 (5 min).
# APPOINTMENT_POLL_MS=300000

# How often to fetch slots and try reschedule (ms). Default 60000 (1 min).
# SLOTS_POLL_MS=60000
